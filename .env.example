# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ─── Meta / Facebook Ads ───────────────────────────────────────────────────────
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=REPLACE_ME
META_APP_SECRET=REPLACE_ME
# Long-lived page access token (never user token in production)
META_ACCESS_TOKEN=REPLACE_ME
# Format: act_XXXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=act_REPLACE_ME
# Your Facebook Page ID (visible in Page settings)
META_PAGE_ID=REPLACE_ME
# Meta Pixel ID for conversion tracking
META_PIXEL_ID=REPLACE_ME

# ─── Campaign Config ───────────────────────────────────────────────────────────
DAILY_AD_BUDGET_USD=5.00
TARGET_COUNTRY=US
TARGET_AGE_MIN=18
TARGET_AGE_MAX=35
# Pause campaigns with ROAS below this threshold after 3 days
MIN_ROAS_THRESHOLD=1.5
# Auto-scale budget multiplier when ROAS > 3.0
SCALE_BUDGET_MULTIPLIER=2.0

# ─── Human-in-the-Loop Gate ────────────────────────────────────────────────────
# Set to true: campaigns queue for manual approval before going live
# Set to false: fully autonomous deployment
HITL_ENABLED=true

# ─── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./mas_state.db
# Public base URL for serving landing pages (set to your ngrok/domain in prod)
PUBLIC_BASE_URL=http://localhost:8000

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=cad.ecom101@gmail.com
# Secret for approving HITL gates via API
ADMIN_SECRET=qms-admin-secret-CHANGE_IN_PROD

# ─── Scraping Behaviour ────────────────────────────────────────────────────────
# Max products to discover per run
MAX_PRODUCTS_PER_RUN=10
# Minimum AliExpress review count to pass validation
MIN_ALIEXPRESS_REVIEWS=500
# Minimum AliExpress star rating (out of 5)
MIN_ALIEXPRESS_RATING=4.5
# Request delay range in seconds (jitter to avoid rate limits)
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
