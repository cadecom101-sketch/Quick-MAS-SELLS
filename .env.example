# ════════════════════════════════════════════════════════════
# Quick-MAS-SELLS  —  Environment Configuration
# Copy this file to .env and fill in every value
# Full instructions in SETUP.md
# ════════════════════════════════════════════════════════════

# ── STEP 1: Anthropic (Claude AI) ────────────────────────────
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── STEP 2: Meta / Facebook Ads ───────────────────────────────
# Full setup guide: SETUP.md → Step 2
# Developer App: https://developers.facebook.com/apps/
META_APP_ID=REPLACE_ME
META_APP_SECRET=REPLACE_ME
# Long-lived Page Access Token (60 days) — see SETUP.md Step 2d
META_ACCESS_TOKEN=REPLACE_ME
# Format: act_XXXXXXXXXXXXXXXXX — Business Manager → Ad Accounts
META_AD_ACCOUNT_ID=act_REPLACE_ME
# Your Facebook Page ID — Page → About → Page ID
META_PAGE_ID=REPLACE_ME
# Events Manager → Pixels → your pixel ID
META_PIXEL_ID=REPLACE_ME

# ── STEP 3: Stripe Checkout ────────────────────────────────────
# Get at: https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ keys first, switch to live when ready
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Webhooks → Add Endpoint → copy Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── STEP 4: ngrok (public HTTPS tunnel) ─────────────────────────
# Free at: https://dashboard.ngrok.com/signup
# Leave empty if you have a real domain
NGROK_AUTHTOKEN=REPLACE_ME_OR_LEAVE_EMPTY

# ── Campaign Config ────────────────────────────────────────────
DAILY_AD_BUDGET_USD=5.00
TARGET_COUNTRY=US
TARGET_AGE_MIN=18
TARGET_AGE_MAX=35
# Kill campaign after 3 days if ROAS below this
MIN_ROAS_THRESHOLD=1.5
# Double budget when ROAS exceeds 3x
SCALE_BUDGET_MULTIPLIER=2.0

# ── Human-in-the-Loop Gate ──────────────────────────────────────
# true  = all campaigns wait for manual approval at /campaigns/awaiting-approval
# false = fully autonomous (be careful!)
HITL_ENABLED=true

# ── App ─────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./mas_state.db
# Set to your ngrok URL or real domain in production
# If NGROK_AUTHTOKEN is set, this gets overridden automatically at startup
PUBLIC_BASE_URL=http://localhost:8000

# ── Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=cad.ecom101@gmail.com
# Change this to a strong secret before going live
ADMIN_SECRET=qms-CHANGE-THIS-TO-SOMETHING-STRONG

# ── Scraping Behaviour ─────────────────────────────────────────
MAX_PRODUCTS_PER_RUN=10
MIN_ALIEXPRESS_REVIEWS=500
MIN_ALIEXPRESS_RATING=4.5
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0

# ── TikTok Ads ────────────────────────────────────────────────
# Get at: https://ads.tiktok.com/marketing_api/homepage/
# Full setup in SETUP.md
TIKTOK_APP_ID=REPLACE_ME_OR_LEAVE_EMPTY
TIKTOK_APP_SECRET=REPLACE_ME_OR_LEAVE_EMPTY
TIKTOK_ACCESS_TOKEN=REPLACE_ME_OR_LEAVE_EMPTY
TIKTOK_ADVERTISER_ID=REPLACE_ME_OR_LEAVE_EMPTY
TIKTOK_PIXEL_ID=REPLACE_ME_OR_LEAVE_EMPTY

# ── Email Alerts (Resend) ──────────────────────────────────────
# Free 3,000 emails/month at: https://resend.com
# Sends: HITL approval alerts, campaign scaled/killed, daily digest, order confirmations
RESEND_API_KEY=re_REPLACE_ME
# Must be a verified domain in Resend. Use onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=noreply@quick-mas-sells.com

# ── Spend Guardrails ────────────────────────────────────────────
# Hard cap: pause all campaigns if total daily spend exceeds this
MAX_TOTAL_DAILY_SPEND_USD=50.00
# Kill campaign if ROAS below this threshold within first 6-24 hours (catastrophic failure)
EARLY_KILL_ROAS_THRESHOLD=0.3

# ── Optional: Shopify + DSers Fulfilment ───────────────────────
# See SETUP.md Step 10
SHOPIFY_STORE_URL=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
